/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self' https://static.cloudflareinsights.com; style-src 'self'; connect-src 'self' https://cloudflareinsights.com https://cbc688.goatcounter.com

/index.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self' https://static.cloudflareinsights.com; style-src 'self'; connect-src 'self' https://cloudflareinsights.com https://cbc688.goatcounter.com

/about.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self' https://static.cloudflareinsights.com; style-src 'self'; connect-src 'self' https://cloudflareinsights.com https://cbc688.goatcounter.com

/articles.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self' https://static.cloudflareinsights.com; style-src 'self'; connect-src 'self' https://cloudflareinsights.com https://cbc688.goatcounter.com

/issues.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self' https://static.cloudflareinsights.com; style-src 'self'; connect-src 'self' https://cloudflareinsights.com https://cbc688.goatcounter.com

/post.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self' https://static.cloudflareinsights.com; style-src 'self'; connect-src 'self' https://cloudflareinsights.com https://cbc688.goatcounter.com

/*.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/robots.txt
  Cache-Control: public, max-age=3600

/rss.xml
  Cache-Control: public, max-age=3600

/.well-known/security.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=UTF-8

/admin/*
  Cache-Control: no-cache, max-age=0
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https: blob:; media-src 'self' blob:; font-src 'self' data:; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.github.com https://github.com https://raw.githubusercontent.com https://media.githubusercontent.com https://avatars.githubusercontent.com https://uploads.github.com; form-action 'self'

/admin/config.yml
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/api/auth
  Content-Security-Policy: default-src 'none'; base-uri 'none'; frame-ancestors 'none'; img-src 'none'; script-src 'none'; style-src 'none'; connect-src 'none'; form-action 'none'

/api/r2-upload-sign
  Content-Security-Policy: default-src 'none'; base-uri 'none'; frame-ancestors 'none'; img-src 'none'; script-src 'none'; style-src 'none'; connect-src 'none'; form-action 'none'

/api/callback
  Content-Security-Policy: default-src 'none'; base-uri 'none'; frame-ancestors 'none'; img-src 'none'; script-src 'unsafe-inline'; style-src 'none'; connect-src 'none'; form-action 'none'

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/posts/*
  Cache-Control: public, max-age=0, must-revalidate
